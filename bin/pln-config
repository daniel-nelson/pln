#!/usr/bin/env bash
# pln-config — read/write ~/.pln/config.yaml
#
# Usage:
#   pln-config get <key>          — read a config value
#   pln-config set <key> <value>  — write a config value
#   pln-config list               — show all config
#
# Env overrides (for testing):
#   PLN_STATE_DIR  — override ~/.pln state directory
set -euo pipefail

STATE_DIR="${PLN_STATE_DIR:-$HOME/.pln}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: pln-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: pln-config set <key> <value>}"
    VALUE="${3:?Usage: pln-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      # Portable in-place rewrite (avoids BSD vs GNU `sed -i` divergence)
      grep -v -E "^${KEY}:" "$CONFIG_FILE" > "$CONFIG_FILE.tmp" 2>/dev/null || true
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE.tmp"
      mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: pln-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
